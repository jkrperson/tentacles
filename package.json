{
  "name": "tentacles",
  "version": "0.0.14",
  "description": "Modern IDE for agentic engineering. Orchestrate and plan AI agents across projects and workspaces.",
  "license": "Elastic-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/jkrperson/tentacles.git"
  },
  "homepage": "https://github.com/jkrperson/tentacles",
  "bugs": {
    "url": "https://github.com/jkrperson/tentacles/issues"
  },
  "author": "jkrperson",
  "type": "module",
  "scripts": {
    "postinstall": "CXXFLAGS='-Wno-missing-field-initializers' electron-rebuild -f -w node-pty,better-sqlite3",
    "generate:icons": "bun scripts/generate-file-icons.ts",
    "predev": "bun run generate:icons",
    "dev": "vite",
    "prebuild": "bun run generate:icons",
    "build:daemon": "esbuild electron/daemon/daemon.ts --bundle --platform=node --format=esm --outfile=dist-electron/daemon.mjs --external:node-pty --external:better-sqlite3 --loader:.sql=text",
    "build": "tsc && vite build && bun run build:daemon && electron-builder",
    "build:notarized": "tsc && vite build && bun run build:daemon && electron-builder -c.mac.notarize=true",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "pretypecheck": "bun run generate:icons",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "verify:daemon-sqlite": "bun scripts/verify-daemon-sqlite.ts",
    "preview": "vite preview"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@supabase/supabase-js": "^2.99.2",
    "@trpc/client": "^10",
    "@trpc/server": "^10",
    "@types/express": "^5.0.6",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-unicode11": "^0.9.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "better-sqlite3": "^12.8.0",
    "electron-trpc": "^0.7.1",
    "electron-updater": "^6",
    "express": "^5.2.1",
    "monaco-editor": "^0.55.1",
    "node-pty": "^1.1.0",
    "openai": "^6.33.0",
    "posthog-js": "^1.364.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "vscode-jsonrpc": "^8.2.1",
    "vscode-languageserver-protocol": "^3.17.5",
    "ws": "^8.19.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@tailwindcss/vite": "^4.1.18",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.2.3",
    "@types/react": "^18.2.64",
    "@types/react-dom": "^18.2.21",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^7.1.1",
    "@typescript-eslint/parser": "^7.1.1",
    "@vitejs/plugin-react": "^4.2.1",
    "electron": "^30.0.1",
    "electron-builder": "^24.13.3",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "material-icon-theme": "^5.32.0",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.2.2",
    "vite": "^5.1.6",
    "vite-plugin-electron": "^0.28.6",
    "vite-plugin-electron-renderer": "^0.14.5",
    "vitest": "^4.1.5"
  },
  "main": "dist-electron/main.cjs"
}
